@echo off
chcp 65001 > nul
echo ======================================================================
echo ЗАПУСК ЭКОСИСТЕМЫ ХРАНИЛИЩА ДОКУМЕНТОВ С УМНЫМ ПОИСКОМ
echo ======================================================================
echo.

echo [1/4] Проверка и подготовка конфигурационных файлов...
if not exist .env (
    if exist .env.example (
        copy .env.example .env > nul
        echo [OK] Файл конфигурации .env успешно создан на основе шаблона.
    ) else (
        echo [КРИТИЧЕСКАЯ ОШИБКА] Не найден файл шаблона .env.example!
        echo Развертывание прервано.
        pause
        exit /b
    )
) else (
    echo [INFO] Файл конфигурации .env уже существует. Используются текущие параметры.
)
echo.

echo [2/4] Очистка старых конфликтующих контейнеров...
docker compose down

echo [3/4] Запуск Docker Compose контейнеров и сборка бэкенда...
docker compose up --build -d

echo.
echo [4/4] Система разворачивается в фоновом режиме!
echo Пожалуйста, подождите 1-2 минуты, пока загрузчик скачает веса нейросети.
echo.
echo После завершения скачивания проект будет доступен по адресам:
echo - Клиентский интерфейс: http://localhost:8085/
echo - Панель администратора: http://localhost:8085/admin
echo.
echo Для просмотра процесса загрузки ИИ-модели нажмите любую клавишу...
pause > nul
docker logs -f smart_search_model_loader