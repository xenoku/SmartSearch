# ==============================================================================
# КОНФИГУРАЦИОННЫЙ ШАБЛОН ДЛЯ РАЗВЕРТЫВАНИЯ СИСТЕМЫ (.ENV)
# Скопируйте этот файл, переименуйте в .env и укажите ваши параметры.
# ==============================================================================

# 1. Параметры подключения к гибридной СУБД PostgreSQL
# Для Docker Compose (активно по умолчанию):
DATABASE_URL=postgresql://user:password@postgres:5432/vector_db
# Для локального запуска вне Docker (раскомментировать при необходимости):
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/vector_db

# 2. Сетевой адрес ИИ-сервера Ollama (указываем базовый URL без эндпоинтов)
# Для Docker Compose (активно по умолчанию):
OLLAMA_URL=http://ollama:11434
# Для локального запуска вне Docker:
# OLLAMA_URL=http://127.0.0.1:11434

# 3. Название развернутой нейросетевой модели
MODEL_NAME=paraphrase-multilingual

# 4. Безопасность и доступы к API / Панели управления
ADMIN_PASSWORD=admin123
SECRET_KEY=super_secret_crypto_key_999
API_BEARER_TOKEN=smart_search_secret_token_2026