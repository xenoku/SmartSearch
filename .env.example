# ==============================================================================
# КОНФИГУРАЦИОННЫЙ ШАБЛОН ДЛЯ РАЗВЕРТЫВАНИЯ СИСТЕМЫ ВЕКТОРНОГО ХРАНИЛИЩА (.ENV)
# Скопируйте этот файл, переименуйте в .env и укажите ваши реальные параметры.
# ==============================================================================

# 1. Параметры подключения к гибридной СУБД PostgreSQL
# Формат: postgresql://[user]:[password]@[host]:[port]/[database_name]
# Использование 127.0.0.1 вместо localhost принудительно активирует IPv4 стек.
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/vector_db

# 2. Сетевой адрес API-эндпоинта локального ИИ-сервера Ollama
# Путь должен строго вести на эндпоинт извлечения векторов (/api/embeddings)
OLLAMA_URL=http://127.0.0.1:11434/api/embeddings

# 3. Название развернутой нейросетевой модели
# Рекомендуемая мультиязычная модель для обработки кириллицы на CPU: paraphrase-multilingual (размерность 768)
MODEL_NAME=paraphrase-multilingual